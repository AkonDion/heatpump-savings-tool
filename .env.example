# Auth: create a single user (Authentication → Users) and sign in with email + password here.
# Shared report URLs (/xxxx) stay public without login. Disable “Confirm email” for that user if you want
# immediate password sign-in without a confirmation link (Auth → Providers → Email).
# Optional. Share links default to the site in the address bar (good for Vercel).
# Set only for a fixed canonical URL (e.g. custom domain different from where the app is served).
# VITE_SHARE_BASE_URL=https://example.com
# Optional. Defaults to ${VITE_SUPABASE_URL}/functions/v1/report-pdf
